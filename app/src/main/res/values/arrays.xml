<?xml version="1.0" encoding="utf-8"?>
<resources>
    <string-array name="xposed_scope">
        <!-- NSMedia - главное приложение мультимедиа, где формируется
             MusicPlaybackInfoImpl с пустым radioStationName -->
        <item>com.ecarx.multimedia</item>
        <!-- Виджет (полноэкранный режим) -->
        <item>ecarx.xsf.widget</item>
        <!-- NSMediaCenter - системный сервис, через AIDL даёт IMediaInteraction
             к которому обращается NSLauncher для компактного виджета.
             В NSMediaCenter: MusicPlaybackInfoHolder/DimPlaybackInfo.getRadioStationName -->
        <item>ecarx.xsf.mediacenter</item>
        <!-- NSLauncher - сам рендерит компактный виджет 3x1 на главном экране,
             запрашивает имя через IMediaInteraction.getRadioStationName -->
        <item>ecarx.launcher3</item>
        <!-- Сервис радио (на всякий случай) -->
        <item>com.ecarx.radio.service</item>
    </string-array>
</resources>
